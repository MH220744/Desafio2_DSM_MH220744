<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/cancel"
                android:src="@android:drawable/ic_media_previous" />

            <TextView
                android:id="@+id/Titulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/add_destino"
                android:textColor="@color/md_theme_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="Agregar destino" />
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/T_NombreDestino"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/NombreDestino"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/destination_name"
                android:inputType="textCapWords"
                tools:hint="Nombre del destino" />
        </com.google.android.material.textfield.TextInputLayout>

        <Spinner
            android:id="@+id/Pais"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:entries="@array/countries_array"
            tools:listitem="@android:layout/simple_spinner_dropdown_item" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/T_Precio"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/Precio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/package_price"
                android:inputType="numberDecimal"
                tools:hint="Precio del paquete" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/T_Descripcion"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/Descripcion"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="top|start"
                android:hint="@string/trip_description"
                android:inputType="textMultiLine"
                tools:hint="Descripción del viaje" />
        </com.google.android.material.textfield.TextInputLayout>

        <ImageView
            android:id="@+id/Preview"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="14dp"
            android:background="@color/white"
            android:contentDescription="@string/image_content"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            tools:src="@mipmap/ic_launcher" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/select_image"
            tools:text="Seleccionar imagen" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/save"
            tools:text="Guardar" />
    </LinearLayout>
</ScrollView>
